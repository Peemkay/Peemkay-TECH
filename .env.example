# Copy this file to .env and fill in real values. Never commit the real .env.

# A long, random string. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Set to false in production (default is already false if unset)
FLASK_DEBUG=false

SITE_URL=https://peemkay.pythonanywhere.com
CONTACT_EMAIL=mubarakabubakarbako@gmail.com

# Optional social links — leave blank to hide the icon
LINKEDIN_URL=
TWITTER_URL=
WHATSAPP_URL=

# Database (SQLite by default — fine for a single-admin portfolio).
# Leave unset to use instance/app.db automatically. If you do set this,
# use an ABSOLUTE path (sqlite:////full/path/to/app.db — four slashes)
# or a different engine's connection string entirely.
DATABASE_URL=

# Set to true once the site is served over HTTPS (PythonAnywhere does this
# by default). Keep false for local http:// development.
SESSION_COOKIE_SECURE=false

# Bootstrap the first admin account automatically on startup. Only used
# while no admin user exists yet — safe to leave set afterward, or run
# `flask create-admin` instead if you'd rather be prompted interactively.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional: send an email notification for every contact-form submission.
# Submissions are always saved to the database regardless of these settings.
MAIL_ENABLED=false
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_RECIPIENT=
