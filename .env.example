# Copy this file to .env and fill in real values. Never commit the real .env.

# A long, random string. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Set to false in production (default is already false if unset)
FLASK_DEBUG=false

SITE_URL=https://peemkay.pythonanywhere.com
CONTACT_EMAIL=mubarakabubakarbako@gmail.com

# Optional social links — leave blank to hide the icon
LINKEDIN_URL=
TWITTER_URL=
WHATSAPP_URL=

# Optional: send an email notification for every contact-form submission.
# Submissions are always saved to the database regardless of these settings.
MAIL_ENABLED=false
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_RECIPIENT=
